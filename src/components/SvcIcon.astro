---
// Ikony služeb — klíč vybírá editor v CMS, SVG zůstávají v kódu.
interface Props { name: string }
const { name } = Astro.props;
const icons: Record<string, string> = {
  phone: '<rect x="7" y="2" width="10" height="20" rx="2"/><line x1="11" y1="18" x2="13" y2="18"/>',
  globe: '<circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15 15 0 0 1 0 20M12 2a15 15 0 0 0 0 20"/>',
  tv: '<rect x="2" y="6" width="20" height="13" rx="2"/><path d="m9 2 3 4 3-4"/>',
  list: '<path d="M4 4h16v16H4z"/><path d="M8 9h8M8 13h6"/>',
  headphones: '<path d="M3 18v-6a9 9 0 0 1 18 0v6"/><path d="M21 19a2 2 0 0 1-2 2h-1v-6h3zM3 19a2 2 0 0 0 2 2h1v-6H3z"/>',
  wrench: '<path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>',
};
const body = icons[name] || icons.phone;
---
<div class="svc-icon" aria-hidden="true">
  <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" set:html={body} />
</div>
